# Database — SQLite for local dev, PostgreSQL for production (Supabase)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_YOUR_ANON_KEY"

# Base URL for API responses
AGENTGOODS_BASE_URL="http://localhost:3000"

# Access token signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET="change-me-in-production"
