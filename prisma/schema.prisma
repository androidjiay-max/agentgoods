generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  balance        Int       @default(0) // Available funds: deposits + sales revenue − purchases (cents)
  earnings       Int       @default(0) // Pure sales revenue — informational, never decreases except refunds (cents)
  bonusExpiresAt DateTime? // Signup bonus $5, expires after 14 days — deducted on next login if past
  agents    Agent[]
  products  Product[]           // Products owned by this user (seller)
  ledgerEntries LedgerTransaction[] // Direct ledger reference for audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id            String              @id @default(cuid())
  name          String
  apiKeyHash    String              @unique // SHA-256 hash of the raw API key — never expose
  apiKeyPrefix  String              // First 12 chars of raw key for dashboard display (e.g. "ag_abc123...")
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  maxBudget     Int                 @default(0) // Stored in cents
  currentSpend  Int                 @default(0) // Stored in cents
  transactions  LedgerTransaction[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Product {
  id             String              @id @default(cuid())
  name           String
  description    String
  price          Int                 // Stored in cents
  schemaString   String?             // OpenAI Tool/Function calling JSON schema string
  isSubscription Boolean             @default(false)
  isAvailable    Boolean             @default(true)
  ownerId        String?             // Seller (User) who listed this product — null for legacy/system products
  owner          User?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  transactions   LedgerTransaction[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model LedgerTransaction {
  id             String   @id @default(cuid())
  agentId        String?
  agent          Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  // NOTE: onDelete SetNull preserves transaction history when an Agent is deleted.
  // In production, prefer soft-delete (add isDeleted boolean to Agent) for full audit trail.
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  userId         String?  // Denormalized: the User who owns this ledger entry (for direct audit queries)
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount         Int      // Stored in cents
  type           String   // Valid values: DEPOSIT, PURCHASE, REFUND
  idempotencyKey String?  @unique // Prevent duplicate transactions on retry
  createdAt      DateTime @default(now())

  @@index([agentId])
  @@index([productId])
  @@index([userId])
  @@index([type, createdAt])
  @@index([idempotencyKey])
}
